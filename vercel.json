{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/report",
      "destination": "https://buy.stripe.com/fZu6oz7g43bp56w0oR9bO00",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/counselors",       "destination": "/counselors.html" },
    { "source": "/counselors/setup", "destination": "/counselor-setup.html" },
    { "source": "/sample-report",    "destination": "/sample-report.html" },
    { "source": "/((?!api/).*)",     "destination": "/index.html" }
  ],
  "functions": {
    "api/recommend.js":         { "maxDuration": 60 },
    "api/webhook.js":           { "maxDuration": 90 },
    "api/save-answers.js":      { "maxDuration": 10 },
    "api/counselor-profile.js": { "maxDuration": 10 },
    "api/results.js":           { "maxDuration": 10 }
  }
}
