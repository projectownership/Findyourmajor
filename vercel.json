{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/report",
      "destination": "https://buy.stripe.com/4gM6oz43Sh2faqQ5Jb9bO01",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/counselors",       "destination": "/counselors.html" },
    { "source": "/counselors/setup", "destination": "/counselor-setup.html" },
    { "source": "/sample-report",    "destination": "/sample-report.html" },
    { "source": "/((?!api/).*)",     "destination": "/index.html" }
  ],
  "functions": {
    "api/recommend.js":              { "maxDuration": 300 },
    "api/webhook.js":                { "maxDuration": 30 },
    "api/webhook-application.js":    { "maxDuration": 30 },
    "api/generate-report.js":        { "maxDuration": 300 },
    "api/save-answers.js":           { "maxDuration": 30 },
    "api/counselor-profile.js":      { "maxDuration": 30 },
    "api/results.js":                { "maxDuration": 30 }
  }
}
